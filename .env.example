# Google AI Studio で取得したAPIキー (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# モデルID(省略時は config.py の既定値を使用。既定は両方 flash)
# 深掘りの品質を上げたい場合、課金有効化のうえで MODEL_DEEP=gemini-2.5-pro にする
# (Proは無料枠が0のため、無料キーでは flash のままにすること)
# MODEL_FAST=gemini-2.5-flash
# MODEL_DEEP=gemini-2.5-flash

# YouTube URLをGeminiに直接渡す(1で有効)。無料キーでは text/html エラーに
# なりやすいため既定は0(ダウンロードしてから渡す確実な経路)
# YOUTUBE_DIRECT=0
